generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(EMPLOYEE)
  createdAt DateTime @default(now())

  bookings  Booking[]
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

model Asset {
  id           String      @id @default(uuid())
  name         String
  category     String
  status       AssetStatus @default(AVAILABLE)
  location     String?
  qrCode       String?
  createdAt    DateTime    @default(now())

  bookings     Booking[]
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  MAINTENANCE
  RETIRED
}

model Booking {
  id        String        @id @default(uuid())
  assetId   String
  userId    String
  startTime DateTime
  endTime   DateTime
  purpose   String?
  status    BookingStatus @default(CONFIRMED)
  createdAt DateTime      @default(now())

  asset     Asset         @relation(fields: [assetId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}